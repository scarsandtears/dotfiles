#!/bin/bash

CONFIG_DIR="$HOME/.config"
LOCAL_BIN="$HOME/.local/bin"
HOME_ROOT="$HOME"

mapfile -t FILES < <(
    {
        [ -d "$CONFIG_DIR" ] && find -L "$CONFIG_DIR" -type f 2>/dev/null
        [ -d "$LOCAL_BIN" ] && find -L "$LOCAL_BIN" -type f 2>/dev/null
        find -L "$HOME_ROOT" -maxdepth 1 -mindepth 1 -type f 2>/dev/null
    } | awk '!seen[$0]++'
)

STYLED=()
for f in "${FILES[@]}"; do
    base=$(basename "$f")
    case "$f" in
        "$CONFIG_DIR"/*)
            dir="${f#$CONFIG_DIR/}"
            dir=".config/${dir%/*}"
            ;;
        "$LOCAL_BIN"/*)
            dir=".local/bin"
            ;;
        "$HOME_ROOT"/*)
            dir="~"
            ;;
        *)
            dir="(outro)"
            ;;
    esac
    STYLED+=("$(printf '%-30s [%s]' "$base" "$dir")")
done

SELECTED=$(printf '%s\n' "${STYLED[@]}" | sort -u | dmenu -l 10 -p "Abrir no Neovim:")

[ -z "$SELECTED" ] && exit

NAME=$(echo "$SELECTED" | awk '{print $1}')

for f in "${FILES[@]}"; do
    if [ "$(basename "$f")" = "$NAME" ]; then
        TARGET="$f"
        break
    fi
done

[ -n "$TARGET" ] && setsid -f st -e nvim "$TARGET"
