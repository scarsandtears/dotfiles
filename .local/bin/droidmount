#!/bin/sh
dir="$HOME/Documents/android"
mkdir -p "$dir"
Devices=$(simple-mtpfs -l)

if [ -z "$Devices" ]; then
    notify-send "No devices found"
    exit 1
fi

Device=$(echo "$Devices" | dmenu -l 10 -p "Select device:")

if [ -z "$Device" ]; then
    notify-send "No device selected"
    exit 1
fi

Id="${Device%%:*}"
Name="${Device##*: }"

mkdir -p "$dir/$Name"

if [ -n "$(ls -A "$dir/$Name" 2>/dev/null)" ]; then
    fusermount -u "$dir/$Name" && notify-send "Android Mount" "Device unmounted"
else
    simple-mtpfs --device "$Id" "$dir/$Name" && notify-send "Android Mount" "Mounted in $dir/$Name"
fi
