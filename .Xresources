! X colors.
! Generated by 'wal'
*foreground:        #e0ddde
*background:        #090706
*.foreground:       #e0ddde
*.background:       #090706
emacs*foreground:   #e0ddde
emacs*background:   #090706
URxvt*foreground:   #e0ddde
XTerm*foreground:   #e0ddde
UXTerm*foreground:  #e0ddde
URxvt*background:   [100]#090706
XTerm*background:   #090706
UXTerm*background:  #090706
URxvt*cursorColor:  #e0ddde
XTerm*cursorColor:  #e0ddde
UXTerm*cursorColor: #e0ddde
URxvt*borderColor:  [100]#090706

! Colors 0-15.
*.color0: #090706
*color0:  #090706
*.color1: #A37356
*color1:  #A37356
*.color2: #DD930F
*color2:  #DD930F
*.color3: #B9886D
*color3:  #B9886D
*.color4: #7F7D82
*color4:  #7F7D82
*.color5: #BCAEA9
*color5:  #BCAEA9
*.color6: #CFB1A9
*color6:  #CFB1A9
*.color7: #e0ddde
*color7:  #e0ddde
*.color8: #9c9a9b
*color8:  #9c9a9b
*.color9: #A37356
*color9:  #A37356
*.color10: #DD930F
*color10:  #DD930F
*.color11: #B9886D
*color11:  #B9886D
*.color12: #7F7D82
*color12:  #7F7D82
*.color13: #BCAEA9
*color13:  #BCAEA9
*.color14: #CFB1A9
*color14:  #CFB1A9
*.color15: #e0ddde
*color15:  #e0ddde

! Black color that will not be affected by bold highlighting.
*.color66: #090706
*color66:  #090706

! Xclock colors.
XClock*foreground: #e0ddde
XClock*background: #090706
XClock*majorColor:  rgba:e0/dd/de/ff
XClock*minorColor:  rgba:e0/dd/de/ff
XClock*hourColor:   rgba:e0/dd/de/ff
XClock*minuteColor: rgba:e0/dd/de/ff
XClock*secondColor: rgba:e0/dd/de/ff

! Set depth to make transparency work.
URxvt*depth: 32
